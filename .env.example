# =============================================================
# Salon Platform — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local.
# =============================================================

# ---------------------------------------------------------------
# Lead storage — Google Sheets (no database needed).
# Deploy the Apps Script in docs/sheets-webhook.gs as a Web App and paste
# its /exec URL here. Each demo request is appended as a row.
# SHEETS_WEBHOOK_SECRET is optional — set the same value in the Apps Script
# to reject anyone who doesn't know it. If SHEETS_WEBHOOK_URL is unset, leads
# are captured by email only (see Resend below).
# ---------------------------------------------------------------
SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/XXXXXXXX/exec
# SHEETS_WEBHOOK_SECRET=some-random-string

# Sheet ID (the long string between /d/ and /edit in the sheet URL). Used by
# pages that READ the sheet (reviews hub, complaint re-ping, login) via gviz CSV.
# The sheet must be shared "anyone with the link can view" for reads to work.
SHEETS_SHEET_ID=your-sheet-id-here

# Auth — passwordless magic-link sign-in. Any long random string (e.g.
# `openssl rand -base64 48`). Sign-in emails go through Resend (above);
# delivery to arbitrary inboxes needs a verified Resend domain.
AUTH_SECRET=your-long-random-secret

# Secret protecting cron endpoints (e.g. /api/complaint/reping). Set any random
# string and pass it as `Authorization: Bearer <value>` or `?secret=<value>`.
# CRON_SECRET=some-random-string

# ---------------------------------------------------------------
# Brandfetch — powers /api/brandfetch (logo, brand colors, fonts).
# Get a key at https://developers.brandfetch.com (free tier).
# If unset, the route falls back to a generated palette (no logo).
# ---------------------------------------------------------------
BRANDFETCH_API_KEY=your-brandfetch-api-key-here

# ---------------------------------------------------------------
# Resend — email notifications for demo requests.
# Get a key at https://resend.com (free tier: 100/day).
# If RESEND_API_KEY is unset, email is skipped. Configure at least one of
# SHEETS_WEBHOOK_URL or RESEND_API_KEY or leads have nowhere to go.
# HELP_NOTIFY_EMAIL = inbox that receives alerts.
# HELP_NOTIFY_FROM  = sender; defaults to Resend's onboarding@resend.dev.
# ---------------------------------------------------------------
RESEND_API_KEY=re_your_resend_key_here
HELP_NOTIFY_EMAIL=you@youremail.com
# HELP_NOTIFY_FROM=Salon Platform <hello@yourdomain.com>

# ---------------------------------------------------------------
# Anthropic (Claude) — powers the financial agent at /financials.
# Get a key at https://console.anthropic.com. If unset, the agent
# returns a "not configured" message (the rest of the site still works).
# ---------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ---------------------------------------------------------------
# Stripe Connect — lets each salon link their OWN Stripe (at /settings/stripe).
# We store only their connected-account id (acct_…), never a secret key.
#   STRIPE_SECRET_KEY        — your PLATFORM account secret key (sk_…)
#   STRIPE_CONNECT_CLIENT_ID — from Stripe → Connect settings (ca_…)
#   NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY — platform publishable key (pk_…), for checkout
#   NEXT_PUBLIC_STRIPE_SUBSCRIPTION_URL — Stripe Payment Link for the 7-day trial/subscription CTA
#   STRIPE_PLATFORM_FEE_BPS  — optional platform fee in basis points (e.g. 50 = 0.5%)
# Register <APP_URL>/api/stripe/callback as an OAuth redirect URI in Connect settings.
# ---------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_your_platform_secret_key
STRIPE_CONNECT_CLIENT_ID=ca_your_connect_client_id
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_platform_publishable_key
NEXT_PUBLIC_STRIPE_SUBSCRIPTION_URL=https://buy.stripe.com/your_subscription_link
# STRIPE_PLATFORM_FEE_BPS=50
# Webhook signing secret (Stripe → Developers → Webhooks) for /api/stripe/webhook —
# credits the wallet when a load succeeds.
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ---------------------------------------------------------------
# App URL — used for absolute URL construction (and the Stripe redirect URI).
# ---------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public scheduling link used by the "Schedule a call with Crystal" button.
NEXT_PUBLIC_CRYSTAL_CALENDLY_URL=https://calendly.com/hello-barebranding/30min
